<!DOCTYPE html>
<html lang="en">
<head>
  {% ga4 %}
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {% adsense %}
  <title>{{ title }} | {{ brandName | default(site.name) }}</title>
  <meta name="description" content="{{ description }}">
  <meta name="keywords" content="{{ keywords | default('quantum merlin, numerology, astrology, spiritual tools, cosmic insights') }}">
  <meta name="author" content="Quantum Merlin">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:title" content="{{ title }} | {{ brandName | default(site.name) }}">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:image" content="{{ ogImage | default(site.url + '/assets/tarot/QMTarot.png') }}">
  <meta property="og:site_name" content="{{ brandName | default(site.name) }}">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }} | {{ brandName | default(site.name) }}">
  <meta name="twitter:description" content="{{ description }}">

  <!-- PWA -->
  <meta name="theme-color" content="{{ themeColor | default('#0a0a0f') }}">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Cinzel:wght@400;500;600;700;800;900&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet">

  {% block head %}{% endblock %}
</head>
<body>
  {% block body %}
    {{ content | safe }}
  {% endblock %}

  {% etsyCta %}
  {% block scripts %}{% endblock %}
</body>
</html>
